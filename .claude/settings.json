{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"Arquivo salvo. Lembre-se de commitar quando terminar!\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"Sessao encerrada. Bom trabalho!\""
          }
        ]
      }
    ]
  }
}
